# Frontend environment variables — copy to .env.local for local development
# Never commit .env.local or .env.production with real values

# URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:3000

# Sentry DSN for frontend error tracking (optional)
# Get from https://sentry.io — Project > Settings > Client Keys (DSN)
VITE_SENTRY_DSN=

